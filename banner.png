from PIL import Image, ImageDraw, ImageFont

# Canvas
W, H = 1400, 400
img = Image.new("RGB", (W, H), "#0b0f1a")
draw = ImageDraw.Draw(img)

# Fonts
try:
    title = ImageFont.truetype("DejaVuSans-Bold.ttf", 56)
    sub = ImageFont.truetype("DejaVuSans.ttf", 26)
except:
    title = sub = None

# Title
draw.text((70, 120), "Wash Trade Scanner", fill="white", font=title)

# Subtitle
draw.text((70, 190),
          "Detecting wash trading, fake volume & coordinated wallets",
          fill="#9ca3af",
          font=sub)

# Divider
draw.rectangle((70, 260, 500, 265), fill="#3b82f6")

# Simple graph cluster (right side)
nodes = [(900,120),(1100,160),(1050,300),(850,280),(780,180)]

for x,y in nodes:
    draw.ellipse((x-10,y-10,x+10,y+10), fill="#1f2937")

for i in range(len(nodes)):
    x1,y1 = nodes[i]
    x2,y2 = nodes[(i+1)%len(nodes)]
    draw.line((x1,y1,x2,y2), fill="#3b82f6", width=3)

# Highlight anomaly loop
draw.line((nodes[1], nodes[3]), fill="#ef4444", width=4)

# Save
img.save("wash_trade_banner.png")
print("Saved: wash_trade_banner.png")
