# Database — use strong passwords in production
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_NAME=wash_detector
DATABASE_USER=wash_user
DATABASE_PASSWORD=CHANGE_ME_STRONG_PASSWORD_123
DATABASE_SSL_MODE=require

# Redis
REDIS_URL=redis://localhost:6379/0

# RPC URLs — replace with your actual endpoints
# Use authenticated endpoints; never commit real keys
ETH_RPC_URL=https://eth-mainnet.g.alchemy.com/v2/YOUR_KEY_HERE
BSC_RPC_URL=https://bsc-dataseed1.binance.org
POLYGON_RPC_URL=https://polygon-rpc.com
ARBITRUM_RPC_URL=https://arb1.arbitrum.io/rpc
OPTIMISM_RPC_URL=https://mainnet.optimism.io
BASE_RPC_URL=https://mainnet.base.org
AVALANCHE_RPC_URL=https://api.avax.network/ext/bc/C/rpc
FANTOM_RPC_URL=https://rpc.ftm.tools
CELO_RPC_URL=https://forno.celo.org
GNOSIS_RPC_URL=https://rpc.gnosischain.com
MOONBEAM_RPC_URL=https://rpc.api.moonbeam.network
AURORA_RPC_URL=https://mainnet.aurora.dev
HARMONY_RPC_URL=https://api.harmony.one
CRONOS_RPC_URL=https://evm.cronos.org
METIS_RPC_URL=https://andromeda.metis.io/?owner=1088
BOBA_RPC_URL=https://mainnet.boba.network
ZKSYNC_RPC_URL=https://mainnet.era.zksync.io
POLYGON_ZKEVM_RPC_URL=https://zkevm-rpc.com
LINEA_RPC_URL=https://rpc.linea.build
SCROLL_RPC_URL=https://rpc.scroll.io
MANTLE_RPC_URL=https://rpc.mantle.xyz
KAVA_RPC_URL=https://evm.kava.io
KLAYTN_RPC_URL=https://public-node-api.klaytnapi.com/v1/cypress

# Detection Parameters
WASH_TRADE_TIME_WINDOW_MINUTES=60
MIN_WASH_TRADE_VOLUME_USD=1000
SUSPICIOUS_ACTIVITY_THRESHOLD=0.8

# Bot Detection Thresholds
BOT_TRADE_COUNT_THRESHOLD=10
BOT_TRADE_TIME_THRESHOLD_SECONDS=60
BOT_VOLUME_CV_THRESHOLD=0.5

# Volume Anomaly — mad, iqr, or zscore
VOLUME_ANOMALY_METHOD=mad
VOLUME_ANOMALY_THRESHOLD=3.5
VOLUME_ANOMALY_BUCKET_MINUTES=60
VOLUME_ANOMALY_MIN_TRADES=5

# ML Model
ML_MODEL_PATH=models/ml_model.pkl
ML_CONTAMINATION=0.05
ML_EXPLAINABILITY=true

# Data Retention
TRADE_RETENTION_DAYS=90

# Logging
LOG_LEVEL=INFO

# External APIs
COINGECKO_API_KEY=

# Bot Allowlist — comma-separated addresses to skip
BOT_ALLOWLIST=
