# Database
DATABASE_URL=postgresql+asyncpg://wash_user:wash_pass@localhost:5432/wash_detector

# Redis
REDIS_URL=redis://localhost:6379/0

# RPC URLs (replace with your own keys)
ETH_RPC_URL=https://eth-mainnet.g.alchemy.com/v2/YOUR_KEY
BSC_RPC_URL=https://bsc-dataseed1.binance.org
POLYGON_RPC_URL=https://polygon-rpc.com
ARBITRUM_RPC_URL=https://arb1.arbitrum.io/rpc
OPTIMISM_RPC_URL=https://mainnet.optimism.io
BASE_RPC_URL=https://mainnet.base.org
AVALANCHE_RPC_URL=https://api.avax.network/ext/bc/C/rpc

# Detection Parameters
WASH_TRADE_TIME_WINDOW_MINUTES=60
MIN_WASH_TRADE_VOLUME_USD=1000
SUSPICIOUS_ACTIVITY_THRESHOLD=0.8

# ML Model
ML_MODEL_PATH=models/ml_model.pkl
ML_CONTAMINATION=0.05

# Data Retention
TRADE_RETENTION_DAYS=90

# Logging
LOG_LEVEL=INFO

# External APIs
COINGECKO_API_KEY=your_key_here